                onComplete: () => {
                    gsap.to(".hero-section", {
                        opacity: 0, y: -20, duration: 0.2,
                        onComplete: () => {
                            // 2. Swap HTML
                            appRoot.innerHTML = getDetailsHTML(id);
                            window.scrollTo({ top: 0, behavior: 'smooth' });

                            // 3. Animate In Details
                            const tl = gsap.timeline();
                            tl.fromTo(".back-btn", { opacity: 0, x: -20 }, { opacity: 1, x: 0, duration: 0.4 })
                              .fromTo(".details-header", { opacity: 0, y: 30 }, { opacity: 1, y: 0, duration: 0.6, ease: "power3.out" }, "-=0.2")
                              .fromTo(".bundle-card", { opacity: 0, y: 40, scale: 0.95 }, { opacity: 1, y: 0, scale: 1, duration: 0.6, stagger: 0.1, ease: "back.out(1.1)" }, "-=0.3")
                              .fromTo(".addon-box", { opacity: 0, y: 20 }, { opacity: 1, y: 0, duration: 0.5 }, "-=0.2");
                        }
                    });
                }
            });
        }

        // Transition: Details -> Grid
        function transitionToCategories() {
            // 1. Animate Out Details
            gsap.to([".bundle-card", ".addon-box"], {
                y: 20, opacity: 0, duration: 0.3, stagger: 0.05, ease: "power2.in",
                onComplete: () => {
                    gsap.to([".details-header", ".back-btn"], {
                        opacity: 0, y: 20, duration: 0.2,
                        onComplete: () => {
                            // 2. Call the showCategories function which handles the HTML swap and in-animations
                            showCategories(false);
                        }
                    });
                }
            });
        }

        // Start App
        document.addEventListener("DOMContentLoaded", () => {
            showCategories();
        });

    </script>
</body>
</html>


